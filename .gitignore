# Credentials -- never commit these
.env
.env.local

# User problems -- private work, not part of the template
# Example problems below are explicitly tracked as reference
problems/*/
!problems/.gitkeep
!problems/two_sum/
!problems/two_sum/**
!problems/binary_search_interactive/
!problems/binary_search_interactive/**

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
